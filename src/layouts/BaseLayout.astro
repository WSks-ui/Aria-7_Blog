---
import { ClientRouter } from "astro:transitions";
import CustomCursor from "../components/CustomCursor.astro";
import SideTools from "../components/SideTools.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = "Aria-7th Lab",
  description = "第七咏叹调实验室：Aria-7 的个人剪贴簿、动漫日记与技术笔记。",
  bodyClass = "",
} = Astro.props;

const pageTitle = title === "Aria-7th Lab" ? title : `${title} | Aria-7th Lab`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
    <script is:inline src="/scripts/interactions.js" defer data-astro-rerun></script>
  </head>
  <body class={bodyClass}>
    <div transition:persist="aria-custom-cursor">
      <CustomCursor />
    </div>
    <div transition:persist="aria-side-tools">
      <SideTools />
    </div>
    <slot />
    <script>
      declare global {
        interface Window {
          __ariaRouteEnhancersReady?: boolean;
          __ariaChessLoader?: Promise<void>;
        }
      }

      // 客户端路由只替换页面主体，页面级模块可能被浏览器去重；全站入口负责补齐切页后的增强初始化。
      const syncRouteEnhancers = () => {
        if (!document.querySelector("[data-chess-room]")) return;
        window.__ariaChessLoader = import("../scripts/chess-playroom.js").then(({ initChessPlayroom }) => {
          initChessPlayroom();
        });
      };

      if (!window.__ariaRouteEnhancersReady) {
        window.__ariaRouteEnhancersReady = true;
        document.addEventListener("astro:page-load", syncRouteEnhancers);
      }

      syncRouteEnhancers();
    </script>
  </body>
</html>
