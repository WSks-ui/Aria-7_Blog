---
import { ClientRouter } from "astro:transitions";
import CommandPalette from "../components/CommandPalette.astro";
import CustomCursor from "../components/CustomCursor.astro";
import SideTools from "../components/SideTools.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = "Aria-7th Lab",
  description = "第七咏叹调实验室：Aria-7 的个人剪贴簿、动漫日记与技术笔记。",
  bodyClass = "",
} = Astro.props;

const pageTitle = title === "Aria-7th Lab" ? title : `${title} | Aria-7th Lab`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/runtime-styles.css" data-aria-runtime-styles />
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <div transition:persist="aria-custom-cursor">
      <CustomCursor />
    </div>
    <div transition:persist="aria-side-tools">
      <SideTools />
    </div>
    <CommandPalette />
    <slot />
    <script>
      import { startBootstrap } from "../scripts/bootstrap";

      declare global {
        interface Window {
          __ariaBootstrapReady?: boolean;
          __ariaInteractionsCleanup?: () => void;
          __ariaSplashSeen?: boolean;
          __ariaSplashActive?: boolean;
          __ariaCustomCursorReady?: boolean;
        }
      }

      startBootstrap();
    </script>
  </body>
</html>
