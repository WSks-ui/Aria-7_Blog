---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = "Aria-7th Lab",
  description = "第七咏叹调实验室：Aria-7 的个人剪贴簿、动漫日记与技术笔记。",
  bodyClass = "",
} = Astro.props;

const pageTitle = title === "Aria-7th Lab" ? title : `${title} | Aria-7th Lab`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline src="/scripts/interactions.js" defer></script>
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
