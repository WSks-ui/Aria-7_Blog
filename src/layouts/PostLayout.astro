---
import BaseLayout from "./BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import NavBar from "../components/NavBar.astro";
import GiscusComments from "../components/GiscusComments.astro";
import {
  Activity,
  BookOpen,
  CalendarDays,
  Clock3,
  FileText,
  Folder,
  Hash,
  Tags,
} from "@lucide/astro";
import { readSiteImageDimensions } from "../lib/images";
import "../styles/article.css";

interface TocItem {
  depth: number;
  slug: string;
  text: string;
}

interface ArticleStats {
  posts: number;
  categories: number;
  tags: number;
  words: number;
  runtimeDays: number;
  latestActivityText: string;
  latestActivityDate?: string;
  minutes?: number;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  category?: string;
  cover?: string;
  comment?: boolean;
  words?: number;
  minutes?: number;
  toc?: TocItem[];
  stats?: ArticleStats;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  category,
  cover,
  comment = true,
  words,
  minutes,
  toc = [],
  stats,
} = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  timeZone: "Asia/Shanghai",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
const displayTags = tags.slice(0, 10);
const topToc = toc.filter((item) => item.depth <= 3).slice(0, 16);
const coverDimensions = cover ? await readSiteImageDimensions(cover) : null;
---

<BaseLayout title={title} description={description} bodyClass="inner-page article-page">
  <NavBar compact />
  <main class="page-frame article-frame" data-article-frame>
    <div class="article-page-grid">
      <div class="article-main-column">
        <nav class="article-topic-bar glass-panel" aria-label="文章导航">
          <a class="article-topic-pill article-topic-pill--home" href="/blog">
            <span aria-hidden="true">⌂</span>
            <strong>归档</strong>
          </a>
          {category && <span class="article-topic-pill">{category}</span>}
          {displayTags.slice(0, 2).map((tag) => <span class="article-topic-pill">{tag}</span>)}
        </nav>

        <article class="article-shell glass-panel">
          <header class="article-header">
            <div class="article-header__stats">
              {typeof words === "number" && <span><FileText size={16} aria-hidden="true" />{words.toLocaleString("zh-CN")} 字</span>}
              {typeof minutes === "number" && <span><Clock3 size={16} aria-hidden="true" />{minutes} 分钟</span>}
            </div>
            <h1>{title}</h1>
            <div class="article-meta">
              <span>
                <CalendarDays size={18} aria-hidden="true" />
                <time datetime={pubDate.toISOString()}>{dateFormatter.format(pubDate)}</time>
              </span>
              {
                updatedDate && (
                  <span>
                    <CalendarDays size={18} aria-hidden="true" />
                    <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time>
                  </span>
                )
              }
              {category && <span><BookOpen size={18} aria-hidden="true" />{category}</span>}
              {
                displayTags.length > 0 && (
                  <span class="article-meta__tags">
                    <Hash size={18} aria-hidden="true" />
                    {displayTags.join(" / ")}
                  </span>
                )
              }
            </div>
            <p>{description}</p>
            {
              cover && (
                <img
                  class="article-cover"
                  src={cover}
                  alt=""
                  width={coverDimensions?.width}
                  height={coverDimensions?.height}
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              )
            }
          </header>
          <div class="article-content">
            <slot />
          </div>
        </article>
        {comment && <GiscusComments />}
      </div>

      <aside class="article-side-column" aria-label="文章侧边栏">
        {
          stats && (
            <section class="article-stat-card glass-panel" aria-label="站点统计">
              <h2>站点统计</h2>
              <dl class="article-stat-list">
                <div>
                  <dt><FileText size={18} aria-hidden="true" />文章</dt>
                  <dd>{stats.posts.toLocaleString("zh-CN")}</dd>
                </div>
                <div>
                  <dt><Folder size={18} aria-hidden="true" />分类</dt>
                  <dd>{stats.categories.toLocaleString("zh-CN")}</dd>
                </div>
                <div>
                  <dt><Tags size={18} aria-hidden="true" />标签</dt>
                  <dd>{stats.tags.toLocaleString("zh-CN")}</dd>
                </div>
                <div>
                  <dt><BookOpen size={18} aria-hidden="true" />总字数</dt>
                  <dd>{stats.words.toLocaleString("zh-CN")}</dd>
                </div>
                <div>
                  <dt><Clock3 size={18} aria-hidden="true" />运行时长</dt>
                  <dd data-runtime-days data-runtime-start="2026-05-21T00:00:00+08:00">{stats.runtimeDays.toLocaleString("zh-CN")} 天</dd>
                </div>
                <div>
                  <dt><Activity size={18} aria-hidden="true" />最后活动</dt>
                  <dd data-latest-activity data-activity-date={stats.latestActivityDate}>{stats.latestActivityText}</dd>
                </div>
              </dl>
            </section>
          )
        }

        <section class="article-toc-card glass-panel" aria-label="文章目录">
          <h2>文章目录</h2>
          {
            topToc.length > 0 ? (
              <ol class="article-toc-list">
                {topToc.map((item) => (
                  <li class:list={[`is-depth-${item.depth}`]}>
                    <a href={`#${item.slug}`}>{item.text}</a>
                  </li>
                ))}
              </ol>
            ) : (
              <p class="article-toc-empty">暂无目录</p>
            )
          }
        </section>

        <section class="article-view-toggle glass-panel" aria-label="阅读显示">
          <span class="article-view-toggle__label">显示</span>
          <button class="is-active" type="button" data-article-mode="acrylic" aria-pressed="true">亚克力</button>
          <button type="button" data-article-mode="glass" aria-pressed="false">透明玻璃</button>
          <label class="article-opacity-control">
            <span>透明度</span>
            <input type="range" min="30" max="78" value="58" data-article-opacity aria-label="亚克力透明度" />
            <strong data-article-opacity-value>58%</strong>
          </label>
        </section>

        <aside class="article-progress glass-panel" aria-label="文章阅读进度" data-article-progress>
          <span>阅读进度</span>
          <strong data-article-progress-value>0%</strong>
          <i aria-hidden="true"></i>
        </aside>
      </aside>
    </div>
    <SiteFooter />
  </main>
</BaseLayout>
