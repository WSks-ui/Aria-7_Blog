---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { getPostMetrics } from "../../utils/postMetrics";
import { getBlogStats } from "../../utils/blogStats";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const metrics = getPostMetrics(post.body);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const currentDate = new Date();
const stats = getBlogStats(allPosts, { now: currentDate });
const articleStats = {
  ...stats,
  latestActivityDate: stats.latestActivityDate.toISOString(),
};
---

<PostLayout {...post.data} words={metrics.words} minutes={metrics.minutes} toc={headings} stats={articleStats}>
  <Content />
</PostLayout>
