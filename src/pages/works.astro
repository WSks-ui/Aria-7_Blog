---
import { ExternalLink, GitBranch, GitFork, Sparkles, Star } from "@lucide/astro";
import SiteFooter from "../components/SiteFooter.astro";
import NavBar from "../components/NavBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { repositories } from "../data/repositories";

const languageTone: Record<string, string> = {
  Astro: "work-card__lang--astro",
  CSS: "work-card__lang--css",
  Python: "work-card__lang--python",
  TypeScript: "work-card__lang--typescript",
};

const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<BaseLayout title="Works" description="Aria-7th Lab 的 GitHub 项目展示。" bodyClass="inner-page">
  <NavBar compact />
  <main class="page-frame works-frame" transition:animate="fade">
    <section class="work-grid work-grid--repos" aria-label="GitHub 项目列表">
      {
        repositories.map((repo, index) => (
          <a class="work-card work-card--repo glass-panel" href={repo.url} target="_blank" rel="noreferrer">
            <span class="work-card__pin" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
            <div class="work-card__topline">
              <span class={`work-card__language ${languageTone[repo.language] ?? ""}`}>{repo.language}</span>
              <span class="work-card__mood">
                <Sparkles size={14} aria-hidden="true" />
                {repo.mood}
              </span>
            </div>
            <h2>
              <GitBranch size={20} aria-hidden="true" />
              {repo.name}
            </h2>
            <p>{repo.description}</p>
            <div class="tag-row">
              {repo.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
            <div class="work-card__meta">
              <span><Star size={15} aria-hidden="true" /> {repo.stars}</span>
              <span><GitFork size={15} aria-hidden="true" /> {repo.forks}</span>
              <time datetime={repo.updated}>更新 {dateFormatter.format(new Date(repo.updated))}</time>
              <span class="work-card__open">GitHub <ExternalLink size={14} aria-hidden="true" /></span>
            </div>
          </a>
        ))
      }
    </section>
    <SiteFooter />
  </main>
</BaseLayout>
