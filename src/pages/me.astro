---
import SiteFooter from "../components/SiteFooter.astro";
import NavBar from "../components/NavBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Me" description="Aria-7th Lab 的个人介绍。" bodyClass="inner-page">
  <NavBar compact />
  <main class="page-frame" transition:animate="fade">
    <section class="profile-panel profile-panel--simple glass-panel">
      <div class="profile-avatar" aria-hidden="true">
        <img src="/images/aria-avatar.jpg" alt="" loading="lazy" />
      </div>
      <div>
        <p class="eyebrow">ME / PROFILE</p>
        <h1>Aria-7</h1>
        <p>
          06 年，大学生。这里主要放学习记录、项目复盘和一点日常想法。
        </p>
        <div class="tag-row">
          <span>Aria-7</span>
          <span>ACGN</span>
          <span>Frontend</span>
          <span>AI 绘图</span>
          <span>Linux</span>
        </div>
      </div>
    </section>
    <SiteFooter />
  </main>
</BaseLayout>
