---
import {
  Cloud,
  ChevronLeft,
  ChevronRight,
  Disc3,
  FolderOpen,
  ListMusic,
  Pause,
  Radio,
  Play,
  Sparkles,
  Volume2,
} from "@lucide/astro";
---

<aside class="side-tools" aria-label="Aria Dock 页面控制台" data-side-tools data-music-root>
  <div class="side-tools__tab glass-panel" aria-label="Aria Dock 书签">
    <button
      class="side-tools__open"
      type="button"
      data-console-trigger
      aria-label="展开 Aria Dock 控制台"
      aria-expanded="false"
    >
      <span>ARIA</span>
    </button>
    <button class="side-tools__quick-play" type="button" data-music-toggle aria-label="播放 Aria Radio">
      <Play class="music-icon music-icon--play" size={20} />
      <Pause class="music-icon music-icon--pause" size={20} />
    </button>
  </div>

  <section class="side-console glass-panel" aria-label="Aria-7 控制台" data-side-console>
    <header class="side-console__header">
      <span class="side-console__badge" aria-hidden="true">
        <Sparkles size={18} />
      </span>
      <div>
        <strong>Aria Dock</strong>
        <small>音乐 / 运行时间</small>
      </div>
    </header>

    <section class="music-card" aria-label="音乐播放器" data-music-player data-music-surface>
      <audio data-music-audio preload="none"></audio>
      <div
        class="music-config"
        data-music-config
        data-default-mode="local"
        data-meting-api="https://api.i-meto.com/meting/api?server=:server&type=:type&id=:id&r=:r"
        data-meting-server="netease"
        data-meting-type="playlist"
        data-meting-id="10046455237"
      ></div>

      <div class="music-card__title">
        <span aria-hidden="true"><Radio size={20} /></span>
        <strong>Aria Radio</strong>
        <button class="music-source-toggle" type="button" data-music-source-toggle aria-label="切换音源模式">
          <Cloud class="music-source-toggle__icon music-source-toggle__icon--cloud" size={18} />
          <FolderOpen class="music-source-toggle__icon music-source-toggle__icon--local" size={18} />
        </button>
      </div>

      <div class="music-card__main">
        <div class="music-cover" aria-hidden="true" data-music-cover>
          <div class="music-cover__platter"></div>
          <div class="music-cover__arm">
            <span></span>
          </div>
          <div class="music-disc">
            <div class="music-disc__art"></div>
            <Disc3 size={28} />
          </div>
        </div>
        <div>
          <span class="music-card__eyebrow">正在播放</span>
          <strong data-music-title>Shelter</strong>
          <small data-music-artist>Porter Robinson & Madeon</small>
          <span class="music-card__count" data-music-count>1 / 1</span>
        </div>
      </div>

      <p class="music-lyric" data-music-lyric aria-live="polite">歌词会在播放时显示。</p>

      <div class="music-progress">
        <div class="music-progress__label">
          <span>播放进度</span>
          <strong><span data-music-current>0:00</span> / <span data-music-duration>0:00</span></strong>
        </div>
        <input class="music-range" type="range" min="0" max="100" value="0" step="0.1" data-music-progress aria-label="播放进度" />
      </div>

      <div class="music-controls" aria-label="播放控制">
        <button class="music-icon-button" type="button" data-music-prev aria-label="上一首">
          <ChevronLeft size={24} />
        </button>
        <button class="music-icon-button music-icon-button--primary" type="button" data-music-toggle aria-label="播放">
          <Play class="music-icon music-icon--play" size={28} />
          <Pause class="music-icon music-icon--pause" size={28} />
        </button>
        <button class="music-icon-button" type="button" data-music-next aria-label="下一首">
          <ChevronRight size={24} />
        </button>
      </div>

      <label class="music-volume">
        <span>音量</span>
        <Volume2 size={20} aria-hidden="true" />
        <input class="music-range" type="range" min="0" max="1" value="0.72" step="0.01" data-music-volume aria-label="音量" />
      </label>

      <div class="music-source-panel" data-music-source-panel hidden>
        <div class="music-source-panel__mode">
          <button class="is-active" type="button" data-music-mode="local">
            <FolderOpen size={16} />
            <span>本地音源</span>
          </button>
          <button type="button" data-music-mode="meting">
            <Cloud size={16} />
            <span>Meting</span>
          </button>
        </div>
        <p class="music-source-panel__hint" data-music-source-hint>当前使用本地音源。</p>
      </div>

      <div class="music-playlist">
        <button
          class="music-playlist__toggle"
          type="button"
          data-music-list-toggle
          aria-expanded="false"
          aria-controls="aria-music-playlist"
        >
          <ListMusic size={18} aria-hidden="true" />
          <span>播放列表</span>
          <small data-music-count>1 / 1</small>
        </button>
        <div class="music-playlist__panel" id="aria-music-playlist" data-music-list-panel hidden>
          <div class="music-track-list" data-music-list aria-label="播放列表">
            <!-- 本地曲目列表 -->
            
            <button
              class="is-active"
              type="button"
              data-music-track
              data-src="/audio/Shelter.mp3"
              data-title="Shelter"
              data-artist="Porter Robinson & Madeon"
              data-cover="/audio/cover/shelter.webp"
              data-lyric="/audio/shelter.lrc"
            >
              Shelter
            </button>
          </div>
        </div>
      </div>
    </section>

    <div class="site-runtime" aria-label="博客运行时间">
      <span>运行时长</span>
      <strong data-site-runtime data-runtime-start="2026-05-21T00:00:00+08:00">0 天</strong>
    </div>
  </section>
</aside>
