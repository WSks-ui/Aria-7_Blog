---
import { getCollection } from "astro:content";
import {
  ArrowDown,
  ArrowUp,
  Clock3,
  Command,
  Compass,
  CornerDownLeft,
  ExternalLink,
  FileText,
  GitFork,
  Hash,
  Search,
  SearchX,
  Trash2,
  X,
} from "@lucide/astro";
import { buildSearchIndex, STATIC_PAGE_ENTRIES } from "../utils/searchIndex";

const commandIndex = buildSearchIndex(await getCollection("blog"));
const filterItems = [
  { id: "all", label: "全部", count: commandIndex.length },
  { id: "post", label: "文章", count: commandIndex.filter((entry) => entry.kind === "post").length },
  { id: "tag", label: "标签", count: commandIndex.filter((entry) => entry.kind === "tag").length },
  { id: "project", label: "项目", count: commandIndex.filter((entry) => entry.kind === "project").length },
  { id: "page", label: "页面", count: STATIC_PAGE_ENTRIES.length },
];
---

<div class="command-palette" data-command-palette data-command-index-url="/search-index.json" hidden>
  <button class="command-palette__backdrop" type="button" data-command-close aria-label="关闭全站检索"></button>
  <section
    class="command-palette__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="aria-command-title"
  >
    <header class="command-palette__header">
      <span class="command-palette__badge" aria-hidden="true">
        <Command size={18} stroke-width={2.2} />
      </span>
      <div class="command-palette__title">
        <h2 id="aria-command-title">Aria 全站检索</h2>
      </div>
      <button class="command-palette__close" type="button" data-command-close aria-label="关闭检索" title="关闭检索">
        <X size={17} aria-hidden="true" />
        <kbd>Esc</kbd>
      </button>
    </header>

    <div class="command-search">
      <Search size={19} stroke-width={2.2} aria-hidden="true" />
      <input
        id="aria-command-input"
        type="search"
        role="combobox"
        aria-label="搜索全站内容"
        aria-autocomplete="list"
        aria-controls="aria-command-results"
        aria-expanded="true"
        autocomplete="off"
        spellcheck="false"
        placeholder="搜索文章、标签、项目或页面..."
        data-command-input
      />
      <button class="command-search__clear" type="button" data-command-clear aria-label="清空搜索" title="清空搜索" hidden>
        <X size={16} aria-hidden="true" />
      </button>
      <kbd data-command-shortcut>Ctrl K</kbd>
    </div>

    <nav class="command-filters" aria-label="检索范围">
      {
        filterItems.map((filter, index) => (
          <button
            class:list={["command-filter", { "is-active": index === 0 }]}
            type="button"
            data-command-filter={filter.id}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            <span>{filter.label}</span>
            <small>{filter.count}</small>
          </button>
        ))
      }
    </nav>

    <div id="aria-command-results" class="command-results" data-command-results role="listbox" aria-label="检索结果">
      <div class="command-empty" data-command-empty hidden>
        <SearchX size={26} aria-hidden="true" />
        <strong>这页剪贴簿里暂时没有记录</strong>
        <span>换个关键词，或切换到其他分类看看。</span>
      </div>
    </div>

    <footer class="command-palette__footer">
      <div class="command-palette__status" aria-live="polite">
        <Clock3 size={14} aria-hidden="true" />
        <span data-command-status>常用入口已就绪</span>
        <button type="button" data-command-clear-recent aria-label="清除最近访问" title="清除最近访问" hidden>
          <Trash2 size={14} aria-hidden="true" />
        </button>
      </div>
      <div class="command-palette__keys" aria-hidden="true">
        <span><kbd><ArrowUp size={12} /></kbd><kbd><ArrowDown size={12} /></kbd>选择</span>
        <span><kbd><CornerDownLeft size={12} /></kbd>打开</span>
      </div>
    </footer>

    <template data-command-result-template>
      <a class="command-result" href="#" role="option" data-command-result>
        <span class="command-result__icon" data-command-result-icon aria-hidden="true">
          <FileText size={18} />
        </span>
        <span class="command-result__body">
          <strong data-command-result-title></strong>
          <small data-command-result-description></small>
        </span>
        <span class="command-result__meta">
          <span class="command-result__group" data-command-result-group></span>
          <small data-command-result-extra></small>
        </span>
        <span class="command-result__action" aria-hidden="true">
          <CornerDownLeft class="command-result__enter" size={16} />
          <ExternalLink class="command-result__external" size={16} />
        </span>
      </a>
    </template>

    <div class="command-palette__icons" hidden aria-hidden="true">
      <span data-command-icon="page"><Compass size={18} /></span>
      <span data-command-icon="post"><FileText size={18} /></span>
      <span data-command-icon="tag"><Hash size={18} /></span>
      <span data-command-icon="project"><GitFork size={18} /></span>
    </div>
  </section>
</div>
