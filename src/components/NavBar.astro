---
import { CodeXml, Gamepad2, House, NotebookText, Search, UserRound } from "@lucide/astro";
import { isNavItemActive } from "../scripts/core/navigation";

interface Props {
  compact?: boolean;
  showBrand?: boolean;
}

const { compact = false, showBrand = true } = Astro.props;

const navItems = [
  { href: "/", label: "HOME", sub: "front page", icon: House },
  { href: "/blog", label: "BLOG", sub: "notes", icon: NotebookText },
  { href: "/game", label: "GAME", sub: "playroom", icon: Gamepad2 },
  { href: "/works", label: "WORKS", sub: "projects", icon: CodeXml },
  { href: "/me", label: "ME", sub: "profile", icon: UserRound },
];
---

<header class:list={["site-header", { "site-header--compact": compact, "site-header--brandless": !showBrand }]}>
  {
    showBrand && (
      <a class="brand-pill" href="/" aria-label="Aria-7th Lab home" data-astro-prefetch="hover">
        <span class="brand-mascot" aria-hidden="true">
          <img src="/images/aria-avatar.webp" alt="" width="512" height="512" loading="lazy" decoding="async" />
        </span>
        <strong>Aria-7th Lab</strong>
      </a>
    )
  }
  {(compact || !showBrand) && <span class="nav-hover-zone" aria-hidden="true"></span>}
  {(compact || !showBrand) && <span class="nav-bookmark" aria-hidden="true">MENU</span>}
  <nav class="nav-pill glass-panel" aria-label="主导航">
    {
      navItems.map(({ href, label, sub, icon: Icon }) => (
        <a
          class:list={["nav-link", { active: isNavItemActive(Astro.url.pathname, href) }]}
          href={href}
          aria-current={isNavItemActive(Astro.url.pathname, href) ? "page" : undefined}
          data-astro-prefetch="hover"
        >
          <Icon size={22} stroke-width={2.2} aria-hidden="true" />
          <span>
            <strong>{label}</strong>
            <small>{sub}</small>
          </span>
        </a>
      ))
    }
    <button class="nav-command-trigger" type="button" data-command-trigger aria-label="打开全站命令检索">
      <Search size={20} stroke-width={2.3} aria-hidden="true" />
      <span>
        <strong>SEARCH</strong>
        <small>Ctrl K</small>
      </span>
    </button>
  </nav>
</header>
